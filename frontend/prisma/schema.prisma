generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user") // "user" or "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  charts        Chart[]
  subscriptions Subscription[]
  payments        Payment[]
  reportPurchases ReportPurchase[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Chart {
  id        String   @id @default(cuid())
  userId    String
  name      String
  chartData Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterestEmail {
  id           String   @id @default(cuid())
  email        String   @unique
  registeredAt DateTime @default(now())
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  status             String    @default("active") // active, expired, cancelled
  plan               String    @default("monthly")
  amount             Int       // in paise (50000 = INR 500)
  startDate          DateTime  @default(now())
  endDate            DateTime
  transitAccessUntil DateTime? // how far ahead transit reports are accessible
  dashaAccessUntil   DateTime? // how far ahead dasha reports are accessible
  couponId           String?
  createdAt          DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon? @relation(fields: [couponId], references: [id])
}

model Payment {
  id               String   @id @default(cuid())
  userId           String
  amount           Int      // in paise
  method           String   @default("upi")
  upiTransactionId String?
  status           String   @default("pending") // pending, verified, rejected
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReportPurchase {
  id               String   @id @default(cuid())
  userId           String?
  email            String
  reportType       String   // e.g. "ayurvedic_wellness"
  amount           Int      // in paise (20000 = INR 200)
  upiTransactionId String?
  status           String   @default("pending") // pending, verified, rejected
  birthName        String?  // name entered with birth details
  birthData        Json     // {date, time, place}
  chartData        Json     // full ChartResponse snapshot
  reportData       Json?    // cached generated report content
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ReportCatalog {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g. "life_events_prediction", "ayurvedic_wellness"
  name        String           // display name
  description String?
  price       Int              // in paise (80000 = INR 800)
  active      Boolean  @default(true) // whether purchasable
  adminOnly   Boolean  @default(false) // visible only to admins (for testing)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String    @default("unlimited") // unlimited, percentage, fixed
  value     Int?      // discount value (percentage or fixed paise)
  maxUses   Int?      // null = unlimited uses
  usedCount Int       @default(0)
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  subscriptions Subscription[]
}
