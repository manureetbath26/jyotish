generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user") // "user" or "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  charts          Chart[]
  subscriptions   Subscription[]
  payments        Payment[]
  reportPurchases ReportPurchase[]
  chatSessions    ChatSession[]
  questionBalances UserQuestionBalance[]
  profiles        Profile[]
}

// ---------------------------------------------------------------------------
// Kundli profiles — users' own + added profiles (family/friends)
// Each user has at most one isOwn=true profile (enforced via partial unique).
// ---------------------------------------------------------------------------
model Profile {
  id             String   @id @default(cuid())
  userId         String
  name           String
  dateOfBirth    String   // YYYY-MM-DD
  timeOfBirth    String   // HH:mm
  placeOfBirth   String
  gender         String?  // "male" | "female" | "other"
  relationship   String?  // "self" | "spouse" | "parent" | "child" | "sibling" | "friend" | "other"
  isOwn          Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  chart ProfileChart?
  dailyReadings DailyReading[]

  @@index([userId])
  @@index([userId, isOwn])
}

// ---------------------------------------------------------------------------
// Cached natal chart per profile. One row per profile (unique profileId).
// Invalidated (deleted) when profile birth details change.
// Used by Ashtakvarga + any report page to avoid re-computing the chart.
// ---------------------------------------------------------------------------
model ProfileChart {
  id        String   @id @default(cuid())
  profileId String   @unique
  chartData Json     // full ChartResponse snapshot
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// House significations — single source of truth. 12 rows. Used by the
// yoga, daily, finance, and arudha engines via a cached helper, replacing
// four separate hardcoded maps.
// ---------------------------------------------------------------------------
model HouseSignification {
  house   Int    @id  // 1..12
  /// Classical name with a short English gloss, e.g. "Lagna (Self)"
  name    String
  /// Short theme phrase (daily-reading tone): "self, body, vitality"
  short   String
  /// Fuller signification list (yoga-report tone)
  themes  String
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Daily Perspective cache. One row per (profile, date, tone) — the reading
// is pinned for the calendar day so the LLM call only runs once per user
// per day per tone. If the user swaps tone, a new row is created.
// ---------------------------------------------------------------------------
model DailyReading {
  id         String   @id @default(cuid())
  profileId  String
  /// ISO date (YYYY-MM-DD) in the user's timezone, used as the dedupe key.
  readingDate String
  /// "thoughtful" | "coffee" | "classical"
  tone       String
  facts      Json     // structured facts passed to the composer
  reading    String   // composed natural-language output
  createdAt  DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, readingDate, tone])
  @@index([profileId, readingDate])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Chart {
  id        String   @id @default(cuid())
  userId    String
  name      String
  chartData Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterestEmail {
  id           String   @id @default(cuid())
  email        String   @unique
  registeredAt DateTime @default(now())
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  status             String    @default("active") // active, expired, cancelled
  plan               String    @default("monthly")
  amount             Int       // in paise (50000 = INR 500)
  startDate          DateTime  @default(now())
  endDate            DateTime
  transitAccessUntil DateTime? // how far ahead transit reports are accessible
  dashaAccessUntil   DateTime? // how far ahead dasha reports are accessible
  couponId           String?
  createdAt          DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon? @relation(fields: [couponId], references: [id])
}

model Payment {
  id               String   @id @default(cuid())
  userId           String
  amount           Int      // in paise
  method           String   @default("upi")
  upiTransactionId String?
  status           String   @default("pending") // pending, verified, rejected
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReportPurchase {
  id               String   @id @default(cuid())
  userId           String?
  profileId        String?  // linked profile, if report was run against a saved profile
  email            String
  reportType       String   // e.g. "ayurvedic_wellness"
  amount           Int      // in paise (20000 = INR 200)
  upiTransactionId String?
  status           String   @default("pending") // pending, verified, rejected
  birthName        String?  // name entered with birth details
  birthData        Json     // {date, time, place}
  chartData        Json     // full ChartResponse snapshot
  reportData       Json?    // cached generated report content
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([profileId])
}

model ReportCatalog {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g. "life_events_prediction", "ayurvedic_wellness"
  name        String           // display name
  description String?
  price       Int              // in paise (80000 = INR 800)
  active      Boolean  @default(true) // whether purchasable
  adminOnly   Boolean  @default(false) // visible only to admins (for testing)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatPricingTier {
  id            String   @id @default(cuid())
  name          String           // e.g. "Starter", "Popular", "Pro"
  questionCount Int              // number of questions included
  price         Int              // in paise (9900 = INR 99)
  isMostPopular Boolean  @default(false)
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Wallet of chat-question grants for one user (or one guest, keyed by
/// email). Each row is one purchase or grant — the free-tier 2-pack, a
/// paid tier, or an unlimited coupon. Quota is enforced by SUM across
/// active rows, FIFO-consumed (oldest first) when a question is asked.
///
/// Strictly chat-only — does NOT pool with report purchases or
/// subscriptions. Stacking: two paid 25-packs show as 50 remaining at
/// the user level but stay separate rows for audit.
model UserQuestionBalance {
  id               String   @id @default(cuid())
  /// Owner — exactly one of userId / guestEmail is set. Guests can only
  /// hold a free-tier balance; paid balances always belong to a user.
  userId           String?
  guestEmail       String?
  /// Where this balance came from: "free" | "tier" | "coupon"
  source           String
  sourceTierId     String?
  sourceCouponCode String?
  upiTransactionId String?
  questionLimit    Int      // 2 / N / 999999
  questionsUsed    Int      @default(0)
  amount           Int      @default(0) // paise
  /// "active" while questionsUsed < questionLimit, "exhausted" when reached.
  /// FIFO consumer skips exhausted rows; UI hides them from the breakdown.
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([guestEmail, status])
}

model ChatSession {
  id               String   @id @default(cuid())
  /// Logged-in user, nullable so guests (Ask AI Astrologer 2-question free
  /// trial) can start a session before signing up. When null, the session
  /// is identified by guestEmail (primary) + anonSessionId cookie (browser
  /// continuity).
  userId           String?
  /// UUID held in the `jyotish_anon_id` cookie. Lets the same browser
  /// resume guest sessions even before sign-up. NOT unique — a single
  /// browser may legitimately accumulate multiple sessions over time
  /// (different guest emails). Email is the authoritative quota key.
  anonSessionId    String?
  /// Guest contact captured in the birth form. guestEmail is the primary
  /// quota key — one free trial per email, harder to bypass than a cookie.
  /// On later sign-up we adopt all orphan sessions matching this email.
  guestEmail       String?
  guestName        String?
  chartData        Json              // full ChartResponse snapshot (so no FK needed)
  birthData        Json?             // {date, time, place, name}
  tierId           String?           // nullable for free tier
  questionLimit    Int               // snapshot of allowed questions at purchase time
  questionsUsed    Int      @default(0)
  amount           Int               // paise paid (0 for free/coupon)
  upiTransactionId String?
  couponCode       String?
  status           String   @default("active") // active, exhausted
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user     User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([anonSessionId])
  @@index([guestEmail])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String           // "user" or "assistant"
  content   String
  metadata  Json?            // engine data used to generate answer
  saved     Boolean  @default(false) // user-bookmarked; survives "clear chat"
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, saved])
}

// ---------------------------------------------------------------------------
// Reference / interpretation content (admin-editable)
// ---------------------------------------------------------------------------
model Interpretation {
  id        String   @id @default(cuid())
  category  String   // "chara_role", "chara_by_planet", "chara_lordship", "naisargika", "naisargika_in_house"
  key1      String   // Primary key (role id like "AK" or planet name like "Sun")
  key2      String?  // Secondary key (planet name or house number as string)
  content   Json     // Flexible JSON payload per category
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, key1, key2])
  @@index([category])
}

// ---------------------------------------------------------------------------
// Ashtakvarga rules — bindu contribution tables per classical Jyotish texts
// Source: Jyotish Ashtakavarga by M.S. Mehta, tables on pages 11–13.
// One row per (planet, source); `houses` lists the relative house offsets
// (1-12) from the source at which the planet receives a benefic bindu.
// ---------------------------------------------------------------------------
model AshtakvargaRule {
  id        String   @id @default(cuid())
  planet    String   // "Sun" | "Moon" | "Mars" | "Mercury" | "Jupiter" | "Venus" | "Saturn"
  source    String   // "Sun" | "Moon" | "Mars" | "Mercury" | "Jupiter" | "Venus" | "Saturn" | "Lagna"
  houses    Int[]    // benefic offsets from source (1..12)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planet, source])
}

// ---------------------------------------------------------------------------
// Sarvashtakavarga interpretation rules (house-wise impacts + comparisons).
// Source: https://shilaavinyaas.com/p/sarvashtakavarga-explained-house-wise-impacts-rules-remedies
// Stored as structured JSON per category so rules can be extended later
// without schema migrations.
// ---------------------------------------------------------------------------
model SarvashtakvargaRule {
  id        String   @id @default(cuid())
  category  String   // "house" | "trikona" | "comparison"
  ruleKey   String   // house number ("1".."12") or trikona id or comparison id
  content   Json     // structured payload (see seed script for shape)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, ruleKey])
  @@index([category])
}

// ---------------------------------------------------------------------------
// Yoga rules — planetary combinations from BPHS chapters 34-40.
// Each rule has a structured detector JSON consumed by the yoga engine to
// determine whether the yoga is present in a given chart.
// ---------------------------------------------------------------------------
model YogaRule {
  id            String   @id @default(cuid())
  slug          String   @unique          // "gajakesari", "hamsa_mahapurusha", ...
  name          String                    // "Gaja Kesari Yoga"
  category      String                    // "mahapurusha" | "nabhasa" | "chandra" | "surya" | "raja" | "dhana" | "special" | "dosha"
  chapter       Int                       // BPHS chapter (34-43)
  source        String                    // "BPHS Ch. 36.3-4"
  classicalText String                    // classical translation
  formation     String                    // concise formation rule in plain English
  effects       String                    // what the yoga delivers (classical summary)
  implications  String?                   // rich narrative: how it plays out in life,
                                          // when it activates (dasha/transit), caveats,
                                          // how to maximize.
  importance    Int      @default(3)      // 1-5 for display ordering
  detector      Json                      // typed detector payload for engine
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
}

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String    @default("unlimited") // unlimited, percentage, fixed
  value     Int?      // discount value (percentage or fixed paise)
  maxUses   Int?      // null = unlimited uses
  usedCount Int       @default(0)
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  subscriptions Subscription[]
}

// ---------------------------------------------------------------------------
// Transit interpretation rules (Apr 2026)
//
// All static rules driving the transit ingress composer live here so admins
// can refine wording / add karakas / adjust house weights without redeploy.
// Backend reads via asyncpg with a 5-minute TTL cache. Frontend chat /
// daily / window engines still use file-based copies for now (separate
// migration pass to follow).
//
// Conventions:
//   - planet ∈ {Sun, Moon, Mars, Mercury, Jupiter, Venus, Saturn, Rahu, Ketu}
//   - house  ∈ 1..12
//   - life_area ∈ {career, love_life, health, finances, family, self_confidence}
//   - polarity ∈ {favorable, unfavorable}
//   - classification tag ∈ {kendra, trikona, dusthana, upachaya, maraka,
//                           bhadhaka, panapara, apoklima, ari, mritu, vyaya, ...}
// ---------------------------------------------------------------------------

/// Per-planet "vibe" — flavour text shown in transit cards.
/// Two rows per planet (positive + cautious).
model PlanetVibe {
  planet    String
  polarity  String // "positive" | "cautious"
  text      String
  updatedAt DateTime @updatedAt

  @@id([planet, polarity])
}

/// Multi-label house tags — a house can be both ari (6th) AND upachaya.
/// Stored as one row per (house, tag) so admins can add lineage-specific
/// classifications without schema changes.
model HouseClassification {
  house     Int
  tag       String   // "kendra" | "trikona" | "dusthana" | "upachaya" | "maraka" | "panapara" | "apoklima"
  notes     String?  // optional rationale shown in admin UI
  updatedAt DateTime @updatedAt

  @@id([house, tag])
  @@index([tag])
}

/// Bhavat-bhavam: counting the same house number from a bhava gives a
/// secondary house with similar significations. e.g. (10, 7) means
/// "10th-from-10th = 7th" — so 7H carries career significations.
model BhavatBhavam {
  fromHouse Int
  toHouse   Int
  /// Short label for the relationship, e.g. "10th-from-10th = career via business"
  label     String
  updatedAt DateTime @updatedAt

  @@id([fromHouse, toHouse])
}

/// Per-planet special aspects (beyond the universal 7th).
/// e.g. Mars: rows (Mars, 4) and (Mars, 8). Universal 7th is implicit.
model PlanetSpecialAspect {
  planet         String
  aspectOffset   Int     // 1..12 offset from planet's house
  /// Strength 0-1 — most special aspects are full-strength (1.0) per BPHS
  strength       Float   @default(1.0)
  updatedAt      DateTime @updatedAt

  @@id([planet, aspectOffset])
}

/// Per life-area: which natal houses carry significations + relative weight.
/// weight 1.0 = primary (e.g. 10H for career), 0.7 = secondary, 0.4 = tertiary.
model LifeAreaHouseRelevance {
  lifeArea  String
  house     Int
  weight    Float
  /// Why this house matters for this area (admin-editable rationale)
  rationale String?
  updatedAt DateTime @updatedAt

  @@id([lifeArea, house])
  @@index([lifeArea])
}

/// Per life-area: which planets are natural significators (karakas).
/// Karakas matter regardless of which house they transit.
model LifeAreaKaraka {
  lifeArea  String
  planet    String
  weight    Float    @default(1.0)
  rationale String?
  updatedAt DateTime @updatedAt

  @@id([lifeArea, planet])
  @@index([lifeArea])
}

/// Houses where a planet is classically favorable when transiting from
/// natal lagna. Replaces the old PLANET_CLASSICAL_FAVORABLE_HOUSES dict.
model PlanetFavorableHouse {
  planet    String
  house     Int
  updatedAt DateTime @updatedAt

  @@id([planet, house])
  @@index([planet])
}

/// Per-(planet, area, polarity) interpretation text — the area lens
/// sentence in the composed interpretation. Admin-editable.
model PlanetAreaInterpretation {
  planet    String
  lifeArea  String
  polarity  String // "favorable" | "unfavorable"
  text      String
  updatedAt DateTime @updatedAt

  @@id([planet, lifeArea, polarity])
  @@index([lifeArea])
}

// ---------------------------------------------------------------------------
// Advisory phrasing + tunables (Apr 2026 — finished DB migration)
//
// Closes the loop: every interpretive rule the engine reads now lives in
// Postgres. The remaining hard-coded constants in transit.py are SHASTRA
// invariants (Vimshottari periods, zodiac names, planet-to-swisseph
// number mapping) — definitions of the framework, not interpretive rules.
// ---------------------------------------------------------------------------

/// Per-(planet, life-area, polarity) ADVISORY phrase — the do/avoid line
/// the narrative composer uses. Reads like an astrologer's instruction
/// ("ask for the promotion", "hold back from confrontation"), not a
/// description ("Mars creates conflicts").
model PlanetAreaAdvice {
  planet    String
  lifeArea  String
  polarity  String // "favorable" | "unfavorable"
  text      String
  updatedAt DateTime @updatedAt

  @@id([planet, lifeArea, polarity])
  @@index([lifeArea])
}

/// Yogakaraka mapping — the planet that rules both a kendra (1/4/7/10)
/// AND a trikona (1/5/9) for a given lagna. Invariant per BPHS Ch. 7
/// lordship rule, but stored here so admins can override for lineage
/// variations. Six rows total (Taurus, Cancer, Leo, Libra, Capricorn,
/// Aquarius). Other lagnas have no separate yogakaraka.
model Yogakaraka {
  lagna     String  @id // sign name (Aries, Taurus, ...)
  planet    String
  rationale String?
  updatedAt DateTime @updatedAt
}

/// Casual display label per life-area, used in narrative prose
/// ("love and relationships" instead of "love_life").
model LifeAreaLabel {
  lifeArea     String  @id
  casualLabel  String
  updatedAt    DateTime @updatedAt
}

/// Universal benefic / malefic / neutral classification per planet.
/// Used by the composer for tone modifiers (dusthana battlefield rule).
model PlanetNature {
  planet    String  @id
  nature    String  // "benefic" | "malefic" | "neutral"
  updatedAt DateTime @updatedAt
}

/// Generic key-value rule settings for operational tunables that don't
/// warrant their own table (tracked-planet list, lookback days per planet,
/// gochara thresholds, etc.). Value is JSON to allow lists/maps.
model RuleSetting {
  key       String   @id // e.g. "ingress_tracked_planets", "lookback_days"
  value     Json
  notes     String?
  updatedAt DateTime @updatedAt
}

/// Question classification categories for the chat engine — keywords +
/// relevant houses + relevant planets per life-area. 16 rows. Matches
/// LifeAreaHouseRelevance / LifeAreaKaraka semantically but exists
/// separately because chat needs the keyword list (NLU input) too.
model QuestionCategory {
  id        String   @id  // e.g. "marriage", "career_growth"
  /// Keywords that match this category in user questions (lowercase)
  keywords  String[]
  /// Houses relevant to this category (1-12)
  houses    Int[]
  /// Planets relevant to this category
  planets   String[]
  updatedAt DateTime @updatedAt
}

/// Per-planet BAV (Bhinnashtakvarga) bindu threshold for classical
/// gochara — only when transiting planet's BAV in the transit sign meets
/// or exceeds this is the transit considered "active" (BPHS Ch. 70).
/// 7 rows (Sun-Saturn). Rahu/Ketu use nodal logic, no threshold.
model GocharaThreshold {
  planet    String  @id
  threshold Int     // 0-8 bindus
  updatedAt DateTime @updatedAt
}
