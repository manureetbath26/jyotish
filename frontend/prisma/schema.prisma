generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user") // "user" or "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  charts          Chart[]
  subscriptions   Subscription[]
  payments        Payment[]
  reportPurchases ReportPurchase[]
  chatSessions    ChatSession[]
  profiles        Profile[]
}

// ---------------------------------------------------------------------------
// Kundli profiles — users' own + added profiles (family/friends)
// Each user has at most one isOwn=true profile (enforced via partial unique).
// ---------------------------------------------------------------------------
model Profile {
  id             String   @id @default(cuid())
  userId         String
  name           String
  dateOfBirth    String   // YYYY-MM-DD
  timeOfBirth    String   // HH:mm
  placeOfBirth   String
  gender         String?  // "male" | "female" | "other"
  relationship   String?  // "self" | "spouse" | "parent" | "child" | "sibling" | "friend" | "other"
  isOwn          Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isOwn])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Chart {
  id        String   @id @default(cuid())
  userId    String
  name      String
  chartData Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterestEmail {
  id           String   @id @default(cuid())
  email        String   @unique
  registeredAt DateTime @default(now())
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  status             String    @default("active") // active, expired, cancelled
  plan               String    @default("monthly")
  amount             Int       // in paise (50000 = INR 500)
  startDate          DateTime  @default(now())
  endDate            DateTime
  transitAccessUntil DateTime? // how far ahead transit reports are accessible
  dashaAccessUntil   DateTime? // how far ahead dasha reports are accessible
  couponId           String?
  createdAt          DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon? @relation(fields: [couponId], references: [id])
}

model Payment {
  id               String   @id @default(cuid())
  userId           String
  amount           Int      // in paise
  method           String   @default("upi")
  upiTransactionId String?
  status           String   @default("pending") // pending, verified, rejected
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReportPurchase {
  id               String   @id @default(cuid())
  userId           String?
  profileId        String?  // linked profile, if report was run against a saved profile
  email            String
  reportType       String   // e.g. "ayurvedic_wellness"
  amount           Int      // in paise (20000 = INR 200)
  upiTransactionId String?
  status           String   @default("pending") // pending, verified, rejected
  birthName        String?  // name entered with birth details
  birthData        Json     // {date, time, place}
  chartData        Json     // full ChartResponse snapshot
  reportData       Json?    // cached generated report content
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([profileId])
}

model ReportCatalog {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g. "life_events_prediction", "ayurvedic_wellness"
  name        String           // display name
  description String?
  price       Int              // in paise (80000 = INR 800)
  active      Boolean  @default(true) // whether purchasable
  adminOnly   Boolean  @default(false) // visible only to admins (for testing)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatPricingTier {
  id            String   @id @default(cuid())
  name          String           // e.g. "Starter", "Popular", "Pro"
  questionCount Int              // number of questions included
  price         Int              // in paise (9900 = INR 99)
  isMostPopular Boolean  @default(false)
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ChatSession {
  id               String   @id @default(cuid())
  userId           String
  chartData        Json              // full ChartResponse snapshot (so no FK needed)
  birthData        Json?             // {date, time, place, name}
  tierId           String?           // nullable for free tier
  questionLimit    Int               // snapshot of allowed questions at purchase time
  questionsUsed    Int      @default(0)
  amount           Int               // paise paid (0 for free/coupon)
  upiTransactionId String?
  couponCode       String?
  status           String   @default("active") // active, exhausted
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String           // "user" or "assistant"
  content   String
  metadata  Json?            // engine data used to generate answer
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Reference / interpretation content (admin-editable)
// ---------------------------------------------------------------------------
model Interpretation {
  id        String   @id @default(cuid())
  category  String   // "chara_role", "chara_by_planet", "chara_lordship", "naisargika", "naisargika_in_house"
  key1      String   // Primary key (role id like "AK" or planet name like "Sun")
  key2      String?  // Secondary key (planet name or house number as string)
  content   Json     // Flexible JSON payload per category
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, key1, key2])
  @@index([category])
}

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String    @default("unlimited") // unlimited, percentage, fixed
  value     Int?      // discount value (percentage or fixed paise)
  maxUses   Int?      // null = unlimited uses
  usedCount Int       @default(0)
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  subscriptions Subscription[]
}
